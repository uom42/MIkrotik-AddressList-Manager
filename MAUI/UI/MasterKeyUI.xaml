<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	x:Class="MALM.UI.MasterKeyUI"
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:uomMAUIctl="clr-namespace:uom.controls.MAUI">


	<StackLayout
		Margin="16"
		HorizontalOptions="FillAndExpand"
		VerticalOptions="FillAndExpand">


		<StackLayout
			Margin="16"
			Spacing="16"
			VerticalOptions="Start">

			<StackLayout
				x:Name="slEditFields"
				Spacing="16"
				VerticalOptions="Start">

				<!--  Password edit fields  -->
				<Entry
					x:Name="txtMasterKey1"
					Placeholder="P1"
					ReturnType="Next"
					Style="{StaticResource EntryPassword_100}"
					Text="" />

				<Entry
					x:Name="txtMasterKey2"
					Placeholder="P2"
					ReturnType="Next"
					Style="{StaticResource EntryPassword_100}"
					Text="" />

			</StackLayout>

			<uomMAUIctl:SwitchLabel x:Name="chkRememberMK" Text="dont ask" />

		</StackLayout>


		<StackLayout Margin="16" Spacing="30">
			<!--  Bottom Buttons  -->

			<Button
				x:Name="btnOk"
				Style="{StaticResource ButtonWithShadow}"
				Text="ok" />

			<Button
				x:Name="btnCancel"
				Style="{StaticResource ButtonWithShadow}"
				Text="cancel" />

		</StackLayout>


	</StackLayout>


</ContentPage>
